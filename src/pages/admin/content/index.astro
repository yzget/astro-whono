---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import AdminIcon from '../../../components/admin/AdminIcon.astro';
import AdminReadonlyNotice from '../../../components/admin/AdminReadonlyNotice.astro';
import AdminShell from '../../../components/admin/AdminShell.astro';
import {
  ADMIN_CONTENT_DRAFT_OPTIONS,
  ADMIN_CONTENT_SORT_OPTIONS,
  getAdminContentConsolePageData,
  getAdminContentEntryEditHref,
  getAdminContentFilterHref,
  getAdminContentEntryListHref,
  getAdminContentPublicFallbackLabel,
  getAdminContentCollectionCapability
} from '../../../lib/admin-console/content';
import type {
  AdminContentCollectionKey,
  AdminContentDraftFilter,
  AdminContentIndexItem,
  AdminContentScopeKey,
  AdminContentSortKey
} from '../../../lib/admin-console/content';
import {
  ADMIN_CONTENT_DELETE_API_PATH,
  ADMIN_CONTENT_ENTRY_API_PATH,
  ADMIN_CONTENT_EXPORT_API_PATH
} from '../../../lib/admin-console/admin-api-paths';
import { isAdminContentDeletableCollectionKey } from '../../../lib/admin-console/content-delete-contract';
import { createWithBase, formatISODate } from '../../../utils/format';

const isDev = import.meta.env.DEV;
const shouldShowContentConsole = isDev;
const shouldShowAdminNav = isDev;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../../styles/components/admin/shell.css?url');
const contentHref = '/admin/content/';

const loadContentDevState = async () => {
  const [
    { default: adminContentStylesHref },
    { default: adminContentFilterMenusScriptHref }
  ] = await Promise.all([
    import('../../../styles/components/admin/content/index.css?url'),
    import('../../../scripts/admin-content/filter-menus.ts?url')
  ]);

  return {
    stylesHref: [adminShellStylesHref, adminContentStylesHref],
    filterMenusScriptHref: adminContentFilterMenusScriptHref,
    pageData: await getAdminContentConsolePageData(Astro.url.searchParams)
  };
};

const contentDevState = shouldShowContentConsole ? await loadContentDevState() : null;
const pageData = contentDevState?.pageData ?? null;
// Keep the Svelte list-action island behind a DEV-only dynamic import; production
// builds intentionally skip the Svelte integration.
let ContentListActionsIsland: any = null;
if (import.meta.env.DEV && pageData) {
  ContentListActionsIsland = (await import('../../../components/admin/editor/ContentListActionsIsland.astro')).default;
}
const adminStylesHref = contentDevState?.stylesHref ?? adminShellStylesHref;
const contentConsoleSubtitle = '内容管理';
const resetHref = withBase(contentHref);
const adminContentEntryEndpoint = withBase(ADMIN_CONTENT_ENTRY_API_PATH);
const adminContentExportEndpoint = withBase(ADMIN_CONTENT_EXPORT_API_PATH);
const adminContentDeleteEndpoint = withBase(ADMIN_CONTENT_DELETE_API_PATH);
const adminContentFilterMenusScriptHref = contentDevState?.filterMenusScriptHref ?? null;
const shouldOpenContentFilters = pageData?.hasActiveFilters ?? false;
const clearScopedStateHref = pageData && pageData.collection !== 'all'
  ? withBase(getAdminContentEntryListHref(pageData.collection))
  : resetHref;
const searchPlaceholder = '搜索标题、标签或 slug…';

const getContentEntryExportHref = (collection: string, entryId: string): string => {
  const params = new URLSearchParams({
    collection,
    entryId
  });
  return `${adminContentExportEndpoint}?${params.toString()}`;
};

const getCollectionListHref = (collection: AdminContentCollectionKey): string =>
  withBase(getAdminContentEntryListHref(collection));

const getContentRowDateLabel = (
  item: Pick<AdminContentIndexItem, 'collection' | 'date' | 'dateLabel'>
): string =>
  item.collection === 'bits' && item.date ? formatISODate(item.date) : item.dateLabel;

const getContentPublicLinkLabel = (item: Pick<AdminContentIndexItem, 'collection'>): string => {
  const capability = getAdminContentCollectionCapability(item.collection);
  if (capability.fixedPage) return `转到${capability.label}`;
  if (item.collection === 'bits') return '转到絮语';
  return '转到文章';
};

const getContentInfoActionLabel = (item: Pick<AdminContentIndexItem, 'collection'>): string => {
  const capability = getAdminContentCollectionCapability(item.collection);
  if (!capability.writable) return '查看源信息';
  if (item.collection === 'essay') return '修改信息';
  if (capability.fixedPage) return `${capability.label}信息`;
  return '编辑信息';
};

const getContentPaginationHref = (page: number): string => {
  // 分页只属于具体 collection scope；总览和全部内容搜索不生成分页链接。
  if (!pageData || pageData.collection === 'all') return resetHref;

  const { filterState } = pageData;
  const params = new URLSearchParams({
    collection: pageData.collection
  });

  if (filterState.query) params.set('q', filterState.query);
  if (filterState.draft !== 'all') params.set('draft', filterState.draft);
  if (filterState.tag) params.set('tag', filterState.tag);
  if (filterState.sort !== 'recent') params.set('sort', filterState.sort);
  if (filterState.year !== null) params.set('year', String(filterState.year));
  if (page > 1) params.set('page', String(page));

  return withBase(`${contentHref}?${params.toString()}`);
};

const getContentFilterHref = (updates: {
  collection?: AdminContentScopeKey;
  draft?: AdminContentDraftFilter;
  sort?: AdminContentSortKey;
  year?: string | number | null;
}): string => {
  if (!pageData) return resetHref;

  return withBase(getAdminContentFilterHref(pageData.filterState, updates, contentHref));
};

const defaultDraftFilterLabel = ADMIN_CONTENT_DRAFT_OPTIONS[0].label;
const defaultSortFilterLabel = ADMIN_CONTENT_SORT_OPTIONS[0].label;

const getDraftFilterLabel = (value: AdminContentDraftFilter): string =>
  ADMIN_CONTENT_DRAFT_OPTIONS.find((option) => option.value === value)?.label ?? defaultDraftFilterLabel;

const getSortFilterLabel = (value: AdminContentSortKey): string =>
  ADMIN_CONTENT_SORT_OPTIONS.find((option) => option.value === value)?.label ?? defaultSortFilterLabel;

const currentDraftLabel = pageData ? getDraftFilterLabel(pageData.filterState.draft) : defaultDraftFilterLabel;
const currentSortLabel = pageData ? getSortFilterLabel(pageData.filterState.sort) : defaultSortFilterLabel;
const currentYearLabel = pageData?.filterState.year !== null && pageData?.filterState.year !== undefined
  ? String(pageData.filterState.year)
  : '全部年份';
const shouldEnableScopedFilterMenus = Boolean(
  pageData
  && pageData.collection !== 'all'
  && getAdminContentCollectionCapability(pageData.collection).articleFilters
);
const hiddenFilterInputs = pageData && pageData.collection !== 'all'
  ? [
      { name: 'collection', value: pageData.collection },
      ...(pageData.filterState.draft !== 'all'
        ? [{ name: 'draft', value: pageData.filterState.draft }]
        : []),
      ...(pageData.filterState.sort !== 'recent'
        ? [{ name: 'sort', value: pageData.filterState.sort }]
        : []),
      ...(pageData.filterState.year !== null
        ? [{ name: 'year', value: String(pageData.filterState.year) }]
        : [])
    ]
  : [];
const contentFilterMenuGroupName = 'admin-content-filter-menu';

const getContentEmptyMessage = (sectionLabel: string): string => {
  const query = pageData?.filterState.query.trim() ?? '';
  if (query) return `${sectionLabel}中没有命中“${query}”的内容。`;
  if (pageData?.hasActiveFilters) return `${sectionLabel}中没有符合当前筛选条件的内容。`;
  return `${sectionLabel}中暂无内容。`;
};
---

<AdminLayout title="Content Console" stylesHref={adminStylesHref}>
  <AdminShell
    currentRoute="content"
    title="Content Console"
    subtitle={contentConsoleSubtitle}
    showNav={shouldShowAdminNav}
  >
    {ContentListActionsIsland ? (
      <div slot="status" class="admin-status-slot">
        <ContentListActionsIsland base={base} endpoint={adminContentEntryEndpoint} deleteEndpoint={adminContentDeleteEndpoint} />
      </div>
    ) : null}

    {
      shouldShowContentConsole && pageData ? (
        <section
          class:list={[
            'admin-content-console',
            `admin-content-console--mode-${pageData.mode}`,
            `admin-content-console--scope-${pageData.collection}`
          ]}
          data-admin-content-root
        >
          <form class="admin-content-toolbar" method="get">
            <div class="admin-content-home-toolbar">
              <h2 id="admin-content-home-title" class="admin-content-home-toolbar__title">内容管理</h2>
              <span class="admin-content-home-toolbar__separator" aria-hidden="true">｜</span>

              <input
                id="admin-content-filter-toggle"
                class="admin-sr-only admin-content-filter-toggle"
                type="checkbox"
                checked={shouldOpenContentFilters}
              />
              <label
                class="admin-btn admin-btn--tool admin-btn--compact admin-content-filter-summary"
                for="admin-content-filter-toggle"
              >
                <AdminIcon name="funnel" size={16} />
                <span>筛选</span>
                {
                  pageData.hasActiveFilters ? (
                    <span class="admin-content-filter-summary__count" aria-label={`当前结果数 ${pageData.filteredCount}`}>{pageData.filteredCount}</span>
                  ) : null
                }
              </label>
              <span class="admin-content-home-toolbar__separator admin-content-home-toolbar__separator--search" aria-hidden="true">｜</span>
              <label class="admin-content-toolbar-search">
                <AdminIcon name="search" size={17} />
                <span class="admin-sr-only">搜索</span>
                <input
                  class="admin-content-toolbar-search__input"
                  type="search"
                  name="q"
                  value={pageData.filterState.query}
                  placeholder={searchPlaceholder}
                />
              </label>
              {hiddenFilterInputs.map((input) => (
                <input type="hidden" name={input.name} value={input.value} />
              ))}

              <div id="admin-content-filter-panel" class="admin-content-filter-panel">
                <div class="admin-content-filter-bar">
                  <div class="admin-content-filter-menus" aria-label="内容筛选">
                    <details class="admin-content-filter-menu admin-content-filter-menu--scope" name={contentFilterMenuGroupName}>
                      <summary class="admin-content-filter-trigger">
                        <span>{pageData.collectionLabel}</span>
                        <AdminIcon name="chevron-down" size={14} />
                      </summary>
                      <div class="admin-content-filter-menu__panel" aria-label="内容范围">
                        {
                          pageData.collectionOptions.map((option) => (
                            <a
                              class:list={[
                                'admin-content-filter-option',
                                option.value === pageData.filterState.collection && 'is-active'
                              ]}
                              href={getContentFilterHref({ collection: option.value })}
                            >
                              <span>{option.label}</span>
                              <span class="admin-content-filter-option__count">{option.count}</span>
                            </a>
                          ))
                        }
                      </div>
                    </details>

                    {
                      shouldEnableScopedFilterMenus ? (
                        <details class="admin-content-filter-menu" name={contentFilterMenuGroupName}>
                          <summary class="admin-content-filter-trigger">
                            <span>{currentDraftLabel}</span>
                            <AdminIcon name="chevron-down" size={14} />
                          </summary>
                          <div class="admin-content-filter-menu__panel" aria-label="内容状态">
                            {
                              ADMIN_CONTENT_DRAFT_OPTIONS.map((option) => (
                                <a
                                  class:list={[
                                    'admin-content-filter-option',
                                    option.value === pageData.filterState.draft && 'is-active'
                                  ]}
                                  href={getContentFilterHref({ draft: option.value })}
                                >
                                  {getDraftFilterLabel(option.value)}
                                </a>
                              ))
                            }
                          </div>
                        </details>
                      ) : (
                        <span class="admin-content-filter-trigger admin-content-filter-trigger--disabled" aria-disabled="true">
                          <span>{currentDraftLabel}</span>
                        </span>
                      )
                    }

                    {
                      shouldEnableScopedFilterMenus ? (
                        <details class="admin-content-filter-menu" name={contentFilterMenuGroupName}>
                          <summary class="admin-content-filter-trigger">
                            <span>{currentSortLabel}</span>
                            <AdminIcon name="chevron-down" size={14} />
                          </summary>
                          <div class="admin-content-filter-menu__panel" aria-label="排序方式">
                            {
                              ADMIN_CONTENT_SORT_OPTIONS.map((option) => (
                                <a
                                  class:list={[
                                    'admin-content-filter-option',
                                    option.value === pageData.filterState.sort && 'is-active'
                                  ]}
                                  href={getContentFilterHref({ sort: option.value })}
                                >
                                  {option.label}
                                </a>
                              ))
                            }
                          </div>
                        </details>
                      ) : (
                        <span class="admin-content-filter-trigger admin-content-filter-trigger--disabled" aria-disabled="true">
                          <span>{currentSortLabel}</span>
                        </span>
                      )
                    }

                    {
                      shouldEnableScopedFilterMenus ? (
                        <details class="admin-content-filter-menu" name={contentFilterMenuGroupName}>
                          <summary class="admin-content-filter-trigger">
                            <span>{currentYearLabel}</span>
                            <AdminIcon name="chevron-down" size={14} />
                          </summary>
                          <div class="admin-content-filter-menu__panel" aria-label="内容年份">
                            <a
                              class:list={[
                                'admin-content-filter-option',
                                pageData.filterState.year === null && 'is-active'
                              ]}
                              href={getContentFilterHref({ year: null })}
                            >
                              全部年份
                            </a>
                            {
                              pageData.yearOptions.map((option) => (
                                <a
                                  class:list={[
                                    'admin-content-filter-option',
                                    option.value === (pageData.filterState.year !== null ? String(pageData.filterState.year) : '') && 'is-active'
                                  ]}
                                  href={getContentFilterHref({ year: option.value })}
                                >
                                  <span>{option.label}</span>
                                  <span class="admin-content-filter-option__count">{option.count}</span>
                                </a>
                              ))
                            }
                          </div>
                        </details>
                      ) : (
                        <span class="admin-content-filter-trigger admin-content-filter-trigger--disabled" aria-disabled="true">
                          <span>{currentYearLabel}</span>
                        </span>
                      )
                    }
                  </div>

                  <div class="admin-content-filter-actions">
                    {
                      pageData.mode === 'entry' ? (
                        <a class="admin-btn admin-btn--ghost admin-btn--compact admin-content-reset" href={clearScopedStateHref}>清除定位</a>
                      ) : pageData.mode === 'search' ? (
                        <a class="admin-btn admin-btn--ghost admin-btn--compact admin-content-reset" href={resetHref}>清除搜索</a>
                      ) : pageData.collection !== 'all' ? (
                        <a class="admin-btn admin-btn--ghost admin-btn--compact admin-content-reset" href={clearScopedStateHref}>清除筛选</a>
                      ) : null
                    }
                    {
                      pageData.collection !== 'all' ? (
                        <a class="admin-btn admin-btn--ghost admin-btn--compact admin-content-reset" href={resetHref}>全部内容</a>
                      ) : null
                    }
                  </div>
                </div>
              </div>
            </div>
          </form>

          <div class="admin-content-modules">
            {
              pageData.sections.map((section) => {
                const sectionTitleId = `admin-content-${section.collection}-title`;
                return (
                  <section class="admin-content-module" aria-labelledby={sectionTitleId}>
                    <div class="admin-content-module__head">
                      <h3 id={sectionTitleId}>
                        <span>{section.collectionLabel}</span>
                        <span class="admin-content-module__route">{getAdminContentCollectionCapability(section.collection).consoleSectionHref}</span>
                      </h3>
                      {
                        pageData.mode === 'overview' && section.filteredCount > section.items.length ? (
                          <a class="admin-btn admin-btn--ghost admin-btn--compact" href={getCollectionListHref(section.collection)}>
                            查看全部
                          </a>
                        ) : null
                      }
                    </div>

                    {
                      section.items.length > 0 ? (
                        <ol class="admin-content-list" aria-label={`${section.collectionLabel}内容条目`}>
                          {
                            section.items.map((item, itemIndex) => {
                              const capability = getAdminContentCollectionCapability(item.collection);
                              const editPath = getAdminContentEntryEditHref(item.collection, item.id);
                              const editHref = withBase(editPath);
                              const articleInfoHref = capability.writable
                                ? item.collection === 'essay'
                                  ? withBase(`${editPath}?panel=info`)
                                  : editHref
                                : null;
                              const entryTitleHref = capability.writable ? editHref : getCollectionListHref(item.collection);
                              const publicHref = item.publicHref ? withBase(item.publicHref) : null;
                              const publicFallbackLabel = getAdminContentPublicFallbackLabel(item);
                              const exportHref = getContentEntryExportHref(item.collection, item.id);
                              const deleteUnsupportedReason = capability.deleteUnsupportedReason ?? `当前 collection 暂不支持删除：${item.collection}`;
                              const sourceErrorPanelId = item.sourceError
                                ? `admin-content-source-error-${section.collection}-${itemIndex}`
                                : null;
                              return (
                                <li
                                  class="admin-row admin-row--plain admin-row--interactive admin-row--table admin-content-item"
                                  data-collection={item.collection}
                                  data-admin-content-item
                                >
                                  <p class="admin-content-row-meta">
                                    <span data-admin-content-row-date>{getContentRowDateLabel(item)}</span>
                                  </p>

                                  <div class="admin-content-item__title-row">
                                    <a class="admin-content-row-title" href={entryTitleHref} data-admin-content-row-title>{item.title}</a>
                                    {
                                      item.sourceError && sourceErrorPanelId ? (
                                        <details class="admin-content-source-error">
                                          <summary
                                            class="admin-content-source-error__trigger"
                                            title={item.sourceError}
                                            aria-label={`查看源文件异常：${item.title}`}
                                            aria-controls={sourceErrorPanelId}
                                          >
                                            <AdminIcon name="triangle-alert" size={14} />
                                          </summary>
                                          <div
                                            id={sourceErrorPanelId}
                                            class="admin-content-source-error__panel"
                                            role="note"
                                          >
                                            <p class="admin-content-source-error__label">源文件异常</p>
                                            <p class="admin-content-source-error__message">{item.sourceError}</p>
                                          </div>
                                        </details>
                                      ) : null
                                    }
                                    <span
                                      class="admin-content-row-mark admin-content-row-mark--draft"
                                      data-admin-content-row-draft
                                      hidden={!item.isDraft}
                                    >
                                      [draft]
                                    </span>
                                    <span
                                      class="admin-content-row-mark admin-content-row-mark--archive"
                                      data-admin-content-row-archive
                                      hidden={item.archive !== false}
                                    >
                                      [archive off]
                                    </span>
                                  </div>

                                  <div class="admin-content-item__actions">
                                    {capability.writable ? (
                                      <a class="admin-btn admin-btn--secondary admin-btn--compact" href={editHref}>
                                        编辑
                                      </a>
                                    ) : (
                                      <span
                                        class="admin-btn admin-btn--secondary admin-btn--compact is-disabled"
                                        aria-disabled="true"
                                        title={capability.readonlyReason ?? '当前内容暂不支持编辑'}
                                      >
                                        待接入
                                      </span>
                                    )}
                                    <details class="admin-content-item__more">
                                      <summary class="admin-btn admin-btn--ghost admin-btn--compact">更多</summary>
                                      <div class="admin-content-more-panel" aria-label="内容操作">
                                        <a
                                          class:list={[
                                            'admin-content-menu-item',
                                            !articleInfoHref && 'is-disabled'
                                          ]}
                                          href={articleInfoHref ?? undefined}
                                          data-admin-content-info-action={item.collection === 'essay' ? true : undefined}
                                          data-entry-id={item.collection === 'essay' ? item.id : undefined}
                                          aria-disabled={articleInfoHref ? undefined : 'true'}
                                          title={articleInfoHref ? undefined : capability.readonlyReason ?? '当前内容暂不支持编辑'}
                                          tabindex={articleInfoHref ? undefined : '-1'}
                                        >
                                          <AdminIcon name="admin-page" size={14} />
                                          <span>{getContentInfoActionLabel(item)}</span>
                                        </a>
                                        <a
                                          class:list={[
                                            'admin-content-menu-item',
                                            !publicHref && 'is-disabled'
                                          ]}
                                          href={publicHref ?? undefined}
                                          data-admin-content-row-public-link
                                          aria-disabled={publicHref ? undefined : 'true'}
                                          title={publicHref ? undefined : publicFallbackLabel}
                                          tabindex={publicHref ? undefined : '-1'}
                                        >
                                          <AdminIcon name="link" size={14} />
                                          <span>{getContentPublicLinkLabel(item)}</span>
                                        </a>
                                        <a
                                          class="admin-content-menu-item"
                                          href={exportHref}
                                          data-admin-content-export-action
                                        >
                                          <AdminIcon name="download" size={14} />
                                          <span>导出</span>
                                        </a>
                                        {isAdminContentDeletableCollectionKey(item.collection) ? (
                                          <button
                                            type="button"
                                            class="admin-content-menu-item admin-content-menu-item--danger"
                                            data-admin-content-delete-action
                                            data-collection={item.collection}
                                            data-entry-id={item.id}
                                            data-relative-path={item.relativePath}
                                          >
                                            <AdminIcon name="trash" size={14} />
                                            <span>删除</span>
                                          </button>
                                        ) : (
                                          <span class="admin-content-menu-item admin-content-menu-item--danger is-disabled" aria-disabled="true" title={deleteUnsupportedReason}>
                                            <AdminIcon name="trash" size={14} />
                                            <span>删除</span>
                                          </span>
                                        )}
                                      </div>
                                    </details>
                                  </div>
                                </li>
                              );
                            })
                          }
                        </ol>
                      ) : (
                        <p class="admin-content-empty">
                          {getContentEmptyMessage(section.collectionLabel)}
                        </p>
                      )
                    }
                  </section>
                );
              })
            }
          </div>

          {
            pageData.pagination && pageData.pagination.totalPages > 1 ? (
              <nav class="admin-content-pagination" aria-label="内容分页">
                {pageData.pagination.hasPrev ? (
                  <a class="admin-btn admin-btn--ghost admin-btn--compact" href={getContentPaginationHref(pageData.pagination.page - 1)}>上一页</a>
                ) : (
                  <span class="admin-btn admin-btn--ghost admin-btn--compact is-disabled" aria-disabled="true">上一页</span>
                )}
                <p class="admin-content-pagination__status">
                  {pageData.pagination.page} / {pageData.pagination.totalPages}
                </p>
                {pageData.pagination.hasNext ? (
                  <a class="admin-btn admin-btn--ghost admin-btn--compact" href={getContentPaginationHref(pageData.pagination.page + 1)}>下一页</a>
                ) : (
                  <span class="admin-btn admin-btn--ghost admin-btn--compact is-disabled" aria-disabled="true">下一页</span>
                )}
              </nav>
            ) : null
          }

          {adminContentFilterMenusScriptHref ? (
            <script is:inline type="module" src={adminContentFilterMenusScriptHref}></script>
          ) : null}
        </section>
      ) : (
        <AdminReadonlyNotice>
          若需查看或编辑内容索引，请在本地运行 <code translate="no">npm run dev</code> 后从此入口进入。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>
</AdminLayout>
