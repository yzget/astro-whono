---
import AdminLayout from './AdminLayout.astro';
import AdminDiagnosticPanel from './AdminDiagnosticPanel.astro';
import AdminImagePicker from './AdminImagePicker.astro';
import AdminBitsImageRow from './AdminBitsImageRow.astro';
import AdminReadonlyNotice from './AdminReadonlyNotice.astro';
import AdminShell from './AdminShell.astro';
import {
  getAdminContentEntryListHref,
  type AdminContentCollectionKey
} from '../../lib/admin-console/content';
import {
  ADMIN_CONTENT_DELETE_API_PATH,
  ADMIN_CONTENT_ENTRY_API_PATH,
  ADMIN_CONTENT_EXPORT_API_PATH,
  ADMIN_IMAGE_LIST_API_PATH,
  ADMIN_IMAGE_META_API_PATH,
  ADMIN_IMAGE_UPLOAD_API_PATH,
  ADMIN_PREVIEW_API_PATH
} from '../../lib/admin-console/admin-api-paths';
import {
  readAdminContentEntryEditorPayload
} from '../../lib/admin-console/content-shared';
import { createWithBase } from '../../utils/format';

type Props = {
  collection: AdminContentCollectionKey;
  entryId: string;
  initialArticleInfoOpen?: boolean;
};

const { collection, entryId, initialArticleInfoOpen = false } = Astro.props;

const isDev = import.meta.env.DEV;
const shouldShowContentConsole = isDev;
const shouldShowAdminNav = isDev;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const { default: adminShellStylesHref } = await import('../../styles/components/admin/shell.css?url');

const loadContentEditDevState = async () => {
  const payload = await readAdminContentEntryEditorPayload(collection, entryId);
  const { default: adminContentStylesHref } = await import('../../styles/components/admin/content/index.css?url');

  if (!payload.writable) {
    return {
      payload,
      adminContentScriptHref: null,
      stylesHref: [adminShellStylesHref, adminContentStylesHref]
    };
  }

  if (payload.collection === 'essay') {
    const { default: articleStylesHref } = await import('../../styles/article.css?url');

    return {
      payload,
      adminContentScriptHref: null,
      stylesHref: [adminShellStylesHref, articleStylesHref, adminContentStylesHref]
    };
  }

  const [
    { default: adminContentScriptHref },
    { default: adminImageSharedStylesHref }
  ] = await Promise.all([
    import('../../scripts/admin-content/index.ts?url'),
    import('../../styles/components/admin/images/shared.css?url')
  ]);

  return {
    payload,
    adminContentScriptHref,
    stylesHref: [adminShellStylesHref, adminContentStylesHref, adminImageSharedStylesHref]
  };
};

const contentEditDevState = shouldShowContentConsole ? await loadContentEditDevState() : null;
const selectedEntryEditorPayload = contentEditDevState?.payload ?? null;
const essayEditorPayload = selectedEntryEditorPayload?.writable && selectedEntryEditorPayload.collection === 'essay'
  ? selectedEntryEditorPayload
  : null;
const bitsEditorPayload = selectedEntryEditorPayload?.writable && selectedEntryEditorPayload.collection === 'bits'
  ? selectedEntryEditorPayload
  : null;
const memoEditorPayload = selectedEntryEditorPayload?.collection === 'memo'
  ? selectedEntryEditorPayload
  : null;
// Keep the Svelte island behind a DEV-only dynamic import; a static import leaks
// editor chunks into the production build.
let EssayEditorIsland: any = null;
if (import.meta.env.DEV && essayEditorPayload) {
  EssayEditorIsland = (await import('./editor/EssayEditorIsland.astro')).default;
}
const adminStylesHref = contentEditDevState?.stylesHref ?? adminShellStylesHref;
const collectionHref = withBase(getAdminContentEntryListHref(collection));
const shouldUseLegacyContentEditor = Boolean(bitsEditorPayload);
const shouldUseSvelteEssayEditor = Boolean(EssayEditorIsland);
const contentEditorBodyClass = shouldUseSvelteEssayEditor ? 'admin-page--content-editor' : undefined;
const adminContentEntryEndpoint = withBase(ADMIN_CONTENT_ENTRY_API_PATH);
const adminContentExportEndpoint = withBase(ADMIN_CONTENT_EXPORT_API_PATH);
const adminContentDeleteEndpoint = withBase(ADMIN_CONTENT_DELETE_API_PATH);
const adminPreviewEndpoint = withBase(ADMIN_PREVIEW_API_PATH);
const adminContentBootstrap = bitsEditorPayload
  ? JSON.stringify({
      endpoint: adminContentEntryEndpoint,
      collection: bitsEditorPayload.collection,
      entryId: bitsEditorPayload.entryId,
      revision: bitsEditorPayload.revision
    })
  : null;
const adminImageListEndpoint = withBase(ADMIN_IMAGE_LIST_API_PATH);
const adminImageMetaEndpoint = withBase(ADMIN_IMAGE_META_API_PATH);
const adminImageUploadEndpoint = withBase(ADMIN_IMAGE_UPLOAD_API_PATH);
const contentConsoleSubtitle = selectedEntryEditorPayload
  ? `${selectedEntryEditorPayload.collection} · ${
      selectedEntryEditorPayload.collection === 'essay'
        ? '内容编辑'
        : selectedEntryEditorPayload.writable
          ? 'frontmatter 编辑'
          : '只读详情'
    }`
  : '内容编辑';
const editTitle = selectedEntryEditorPayload
  ? (
      selectedEntryEditorPayload.values.title
      || ('description' in selectedEntryEditorPayload.values ? selectedEntryEditorPayload.values.description : '')
      || selectedEntryEditorPayload.entryId
    )
  : entryId;
const getReadonlyValue = (value: string): string => value || '(未设置)';
const memoReadonlyRows = memoEditorPayload
  ? [
      { label: 'memo.title', value: getReadonlyValue(memoEditorPayload.values.title) },
      { label: 'memo.subtitle', value: getReadonlyValue(memoEditorPayload.values.subtitle) },
      { label: 'memo.date', value: getReadonlyValue(memoEditorPayload.values.date) },
      { label: 'memo.slug', value: getReadonlyValue(memoEditorPayload.values.slug) },
      { label: 'memo.draft', value: memoEditorPayload.values.draft ? 'true' : 'false' }
    ]
  : [];

type AdminBitsImageRowValue = {
  src: string;
  width: string;
  height: string;
  alt: string;
};

const parseInitialBitsImages = (value: string): AdminBitsImageRowValue[] => {
  try {
    const parsed = JSON.parse(value) as unknown;
    if (!Array.isArray(parsed)) return [];
    return parsed
      .filter((item): item is Record<string, unknown> => typeof item === 'object' && item !== null && !Array.isArray(item))
      .map((item) => ({
        src: typeof item.src === 'string' ? item.src : '',
        width: item.width == null ? '' : String(item.width),
        height: item.height == null ? '' : String(item.height),
        alt: typeof item.alt === 'string' ? item.alt : ''
      }));
  } catch {
    return [];
  }
};

const selectedBitsImageRows = bitsEditorPayload
  ? parseInitialBitsImages(bitsEditorPayload.values.imagesText)
  : [];
const bitsImageRows = selectedBitsImageRows.length > 0
  ? selectedBitsImageRows
  : [{ src: '', width: '', height: '', alt: '' }];
---

<AdminLayout
  title={shouldUseSvelteEssayEditor ? editTitle : 'Content Console'}
  stylesHref={adminStylesHref}
  bodyClass={contentEditorBodyClass}
>
  <AdminShell
    currentRoute="content"
    title="Content Console"
    subtitle={contentConsoleSubtitle}
    showHeader={!shouldUseSvelteEssayEditor}
    showNav={shouldShowAdminNav && !shouldUseSvelteEssayEditor}
  >
    {shouldShowContentConsole && shouldUseLegacyContentEditor ? (
      <div slot="status" class="admin-status-slot">
        <p id="admin-content-status-live" class="admin-sr-only" role="status" aria-live="polite" aria-atomic="true"></p>
        <p id="admin-content-status" class="admin-status" data-state="idle">等待编辑</p>
      </div>
    ) : null}

    {
      shouldShowContentConsole && selectedEntryEditorPayload ? (
        <section
          class:list={[
            'admin-content-console',
            'admin-content-edit-page',
            shouldUseSvelteEssayEditor && 'admin-content-edit-page--essay'
          ]}
          data-admin-content-root={shouldUseLegacyContentEditor ? true : undefined}
        >
          <header class="admin-content-page-head">
            <div class="admin-content-page-head__copy">
              {
                shouldUseSvelteEssayEditor ? (
                  <div class="admin-content-title-row">
                    <h2 class="admin-content-heading">{editTitle}</h2>
                    <button
                      class="admin-content-info-trigger"
                      type="button"
                      data-admin-article-info-trigger
                      aria-haspopup="dialog"
                      aria-controls="admin-editor-frontmatter-panel"
                      aria-expanded="false"
                    >
                      修改信息
                    </button>
                  </div>
                ) : (
                  <>
                    <p class="admin-content-kicker">{selectedEntryEditorPayload.collection}</p>
                    <h2 class="admin-content-heading">{editTitle}</h2>
                  </>
                )
              }
              {
                !shouldUseSvelteEssayEditor ? (
                  <p class="admin-content-copy">
                    <code>{selectedEntryEditorPayload.relativePath}</code>
                  </p>
                ) : null
              }
            </div>
            <div
              class="admin-content-actions"
              data-admin-editor-page-actions-host={shouldUseSvelteEssayEditor ? true : undefined}
            >
              {
                shouldUseSvelteEssayEditor ? (
                  <a
                    class="admin-btn admin-btn--ghost admin-btn--compact"
                    href={withBase('/admin/content/')}
                    data-admin-editor-page-actions-fallback
                  >
                    返回
                  </a>
                ) : (
                  <>
                    <a class="admin-btn admin-btn--ghost" href={collectionHref}>返回列表</a>
                    <a class="admin-btn admin-btn--ghost" href={withBase('/admin/content/')}>Content 总入口</a>
                  </>
                )
              }
            </div>
          </header>

          {
            shouldUseSvelteEssayEditor ? (
              <article class="admin-content-editor admin-content-editor--svelte">
                <EssayEditorIsland
                  endpoint={adminContentEntryEndpoint}
                  exportEndpoint={adminContentExportEndpoint}
                  deleteEndpoint={adminContentDeleteEndpoint}
                  previewEndpoint={adminPreviewEndpoint}
                  imageUploadEndpoint={adminImageUploadEndpoint}
                  returnHref={withBase('/admin/content/')}
                  collection="essay"
                  entryId={essayEditorPayload!.entryId}
                  relativePath={essayEditorPayload!.relativePath}
                  defaultPublicSlug={essayEditorPayload!.defaultPublicSlug}
                  revision={essayEditorPayload!.revision}
                  initialFrontmatter={essayEditorPayload!.values}
                  initialBody={essayEditorPayload!.bodyText}
                  initialArticleInfoOpen={initialArticleInfoOpen}
                />
              </article>
            ) : bitsEditorPayload ? (
              <article class="admin-content-editor">
                <div class="admin-content-section-head">
                  <div>
                    <p class="admin-content-kicker">Frontmatter</p>
                    <h3 class="admin-content-section-title">可写字段</h3>
                    <p class="admin-content-muted">
                      当前 bits 编辑器仅开放 frontmatter 写回；正文编辑与预览暂不在此页面提供。
                    </p>
                  </div>
                  <div class="admin-content-actions">
                    <span class="admin-badge">revision</span>
                    <code class="admin-content-editor__revision">{selectedEntryEditorPayload.revision}</code>
                  </div>
                </div>

                <AdminDiagnosticPanel
                  bannerId="admin-content-editor-error-banner"
                  titleId="admin-content-editor-error-title"
                  messageId="admin-content-editor-error-message"
                  listId="admin-content-editor-error-list"
                  title="frontmatter 未写入"
                  label="写入异常"
                />

                <form id="admin-content-editor-form">
                  <div class="admin-content-editor__grid">
                    <>
                          <label class="admin-field admin-content-editor__field" data-field-path="title">
                            <span class="admin-field__label">title（可选）</span>
                            <input class="admin-field__control" id="admin-content-title" name="title" type="text" value={bitsEditorPayload.values.title} />
                            <p class="admin-content-editor__error" data-field-error="title" hidden></p>
                          </label>

                          <label class="admin-field admin-content-editor__field" data-field-path="date">
                            <span class="admin-field__label">date</span>
                            <input class="admin-field__control" id="admin-content-date" name="date" type="text" value={bitsEditorPayload.values.date} />
                            <p class="admin-content-editor__error" data-field-error="date" hidden></p>
                          </label>

                          <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="description">
                            <span class="admin-field__label">description</span>
                            <textarea class="admin-field__control" id="admin-content-description" name="description">{bitsEditorPayload.values.description}</textarea>
                            <p class="admin-content-editor__error" data-field-error="description" hidden></p>
                          </label>

                          <label class="admin-field admin-content-editor__field admin-field--full" data-field-path="tags">
                            <span class="admin-field__label">tags（每行一个）</span>
                            <textarea class="admin-field__control" id="admin-content-tags" name="tagsText">{bitsEditorPayload.values.tagsText}</textarea>
                            <p class="admin-content-editor__error" data-field-error="tags" hidden></p>
                          </label>

                          <label class="admin-field admin-content-editor__field" data-field-path="authorName">
                            <span class="admin-field__label">author.name</span>
                            <input class="admin-field__control" id="admin-content-author-name" name="authorName" type="text" value={bitsEditorPayload.values.authorName} />
                            <p class="admin-content-editor__error" data-field-error="authorName" hidden></p>
                          </label>

                          <label class="admin-field admin-content-editor__field" data-field-path="authorAvatar">
                            <span class="admin-field__label">author.avatar</span>
                            <input class="admin-field__control" id="admin-content-author-avatar" name="authorAvatar" type="text" value={bitsEditorPayload.values.authorAvatar} />
                            <p class="admin-content-editor__error" data-field-error="authorAvatar" hidden></p>
                          </label>

                          <div class="admin-field admin-content-editor__field admin-field--full" data-field-path="imagesText">
                            <div class="admin-content-image-editor__header">
                              <span class="admin-field__label">images</span>
                              <button
                                class="admin-btn admin-btn--ghost admin-content-image-editor__add"
                                id="admin-content-image-add"
                                type="button"
                              >
                                + 添加图片
                              </button>
                            </div>
                            <input
                              id="admin-content-images-json"
                              name="imagesText"
                              type="hidden"
                              value={bitsEditorPayload.values.imagesText}
                            />
                            <p class="admin-content-image-editor__hint">
                              保持现有 `bits.images` 协议：本地相对路径或 `https://` 远程 URL；宽高可留空，本地图片可通过选择器自动回填。
                            </p>
                            <p class="admin-content-editor__error" data-field-error="imagesText" hidden></p>
                            <div class="admin-content-image-editor" id="admin-content-image-editor">
                              {
                                bitsImageRows.map((image, index) => (
                                  <AdminBitsImageRow image={image} index={index} />
                                ))
                              }
                            </div>
                            <template id="admin-content-image-row-template">
                              <AdminBitsImageRow image={{ src: '', width: '', height: '', alt: '' }} index={0} />
                            </template>
                          </div>

                          <div class="admin-content-editor__toggles">
                            <label class="admin-toggle-row">
                              <input id="admin-content-draft" name="draft" type="checkbox" checked={bitsEditorPayload.values.draft} />
                              <span>draft</span>
                            </label>
                          </div>
                    </>
                  </div>
                </form>

                <article id="admin-content-write-preview" class="admin-content-write-preview" hidden>
                  <p id="admin-content-write-preview-title" class="admin-content-section-title">dry-run 结果</p>
                  <p id="admin-content-write-preview-body" class="admin-content-copy"></p>
                  <ul id="admin-content-write-preview-list" class="admin-content-editor__preview-list"></ul>
                </article>

                <div class="admin-content-toolbar__footer admin-content-editor__actions">
                  <p class="admin-content-muted">
                    真实写盘前会再次执行 revision 校验；若当前条目已被外部修改，后台会拒绝覆盖并要求刷新。
                  </p>
                  <div class="admin-content-actions">
                    <button id="admin-content-dry-run" class="admin-btn admin-btn--secondary" type="button">执行 dry-run</button>
                    <button id="admin-content-save" class="admin-btn admin-btn--primary" type="button">保存 frontmatter</button>
                  </div>
                </div>

                <div id="admin-content-bootstrap" hidden>{adminContentBootstrap}</div>
              </article>
            ) : (
              <article class="admin-content-readonly">
                <div class="admin-content-section-head">
                  <div>
                    <p class="admin-content-kicker">Readonly</p>
                    <h3 class="admin-content-section-title">当前 collection 保持只读</h3>
                    <p class="admin-content-copy">{selectedEntryEditorPayload.readonlyReason}</p>
                  </div>
                </div>
                <dl class="admin-data-meta admin-content-detail-meta">
                  {
                    memoReadonlyRows.map((row) => (
                      <>
                        <dt class="admin-data-meta__label">{row.label}</dt>
                        <dd class="admin-data-meta__value">{row.value}</dd>
                      </>
                    ))
                  }
                </dl>
              </article>
            )
          }
        </section>
      ) : (
        <AdminReadonlyNotice>
          若需查看或编辑内容索引，请在本地运行 <code translate="no">npm run dev</code> 后从此入口进入。
        </AdminReadonlyNotice>
      )
    }
  </AdminShell>

  {
    shouldShowContentConsole && shouldUseLegacyContentEditor ? (
      <AdminImagePicker listEndpoint={adminImageListEndpoint} metaEndpoint={adminImageMetaEndpoint} />
    ) : null
  }

  {
    shouldShowContentConsole && contentEditDevState?.adminContentScriptHref ? (
      <script is:inline type="module" src={contentEditDevState.adminContentScriptHref}></script>
    ) : null
  }
</AdminLayout>
